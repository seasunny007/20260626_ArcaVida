# Required for live AI integrations
TELEGRAM_TOKEN=your_bot_token_here
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
TRANSLATION_PROVIDER=llm
GOOGLE_APPLICATION_CREDENTIALS=path/to/google_credentials.json_optional
SOURCE_CHAT_HASH_SALT=replace_with_a_high_entropy_random_secret
OPERATOR_CHAT_IDS=123456789,987654321
ADMIN_PASSWORD=replace_with_a_local_admin_password
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# Optional
DATABASE_URL=sqlite:///./arca_vida.db
WEBHOOK_URL=https://your-domain.example/webhook
WEBHOOK_SECRET_PATH=replace_with_a_random_webhook_path_not_the_bot_token
LOG_LEVEL=INFO
ENVIRONMENT=development