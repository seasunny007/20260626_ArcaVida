{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ArcaVida: pytest",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "pytest", "-q"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONDONTWRITEBYTECODE": "1"
        }
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}